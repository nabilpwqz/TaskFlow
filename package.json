  "version": "1.0.0",
  "description": "TaskFlow - Freelance Services Marketplace API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "marketplace",
    "freelance",
    "nodejs"
  ],
  "author": "TaskFlow",
  "license": "MIT",
  "dependencies": {
